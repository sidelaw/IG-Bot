# Copy to .env and fill in. .env is gitignored. NEVER commit real values.

# Reddit needs NO credentials — the source uses the public RSS feed.

# X (Twitter) API v2 — App-only Bearer token. Pay-per-use (~$0.005/post read
# since Feb 2026); each search run costs money.
X_BEARER_TOKEN=

# Instagram (Instagram Login flow). Per-account, keyed by uppercased account id.
# Token + the IG user id you publish as. Example for account id "acct_main":
IGBOT_TOKEN_ACCT_MAIN=
IGBOT_IGID_ACCT_MAIN=

# Public media host (S3-compatible: AWS S3 or Cloudflare R2). boto3's standard
# credential env vars:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Host settings can also come from env (so Codespaces/CI secrets need no file
# edits). These override config.toml's [host] when set:
IGBOT_HOST_BUCKET=
IGBOT_HOST_ENDPOINT=
IGBOT_HOST_PUBLIC_URL=
