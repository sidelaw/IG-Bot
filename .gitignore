# Secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key
secrets.toml
config.toml

# State / media (holds tokens + downloaded third-party media).
# Anchored to repo root with a leading slash so these do NOT match the source
# package src/igbot/media/ (an unanchored `media/` matches it at any depth).
*.db
*.db-journal
*.db-wal
*.db-shm
/work/
/media/

